        @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@300;400;500;700;900&family=Rajdhani:wght@500;600;700&display=swap');
        
        body { 
            background-color: #030b14; 
            color: #e2e8f0; 
            font-family: 'Inter', sans-serif; 
            scroll-behavior: smooth; 
            overflow-x: hidden;
        }

        /* Tech Grid & Scanline Background */
        .bg-tech-grid {
            position: absolute;
            inset: 0;
            background-size: 50px 50px;
            background-image: 
                linear-gradient(to right, rgba(0, 243, 255, 0.05) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(0, 243, 255, 0.05) 1px, transparent 1px);
            z-index: -2;
        }

        .screen-scanline {
            width: 100%;
            height: 100px;
            background: linear-gradient(to bottom, transparent, rgba(0, 243, 255, 0.2), transparent);
            position: fixed;
            top: 0; left: 0;
            z-index: 50;
            pointer-events: none;
            opacity: 0.3;
        }

        /* Iron Man Click Ripple Effect */
        .hud-click-ripple {
            position: fixed;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(0, 243, 255, 0.8);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            animation: rippleAnim 0.6s cubic-bezier(0.1, 0.8, 0.3, 1) forwards;
            z-index: 9999;
        }
        .hud-click-ripple::after {
            content: '';
            position: absolute;
            inset: 4px;
            border: 1px dotted rgba(0, 243, 255, 0.5);
            border-radius: 50%;
        }

        @keyframes rippleAnim {
            0% { transform: translate(-50%, -50%) scale(1); opacity: 1; box-shadow: 0 0 10px #00f3ff, inset 0 0 10px #00f3ff; }
            100% { transform: translate(-50%, -50%) scale(6); opacity: 0; box-shadow: 0 0 50px #00f3ff, inset 0 0 50px #00f3ff; }
        }

        /* Glass HUD Elements */
        .hud-panel {
            background: rgba(3, 11, 20, 0.8);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(0, 243, 255, 0.2);
            box-shadow: 0 0 20px rgba(0, 243, 255, 0.05), inset 0 0 10px rgba(0, 243, 255, 0.02);
            position: relative;
            transition: all 0.3s ease;
        }
        
        .hud-panel::before {
            content: '';
            position: absolute;
            top: -1px; left: -1px;
            width: 20px; height: 20px;
            border-top: 2px solid #00f3ff;
            border-left: 2px solid #00f3ff;
            opacity: 0.7;
            transition: width 0.3s, height 0.3s;
        }
        
        .hud-panel::after {
            content: '';
            position: absolute;
            bottom: -1px; right: -1px;
            width: 20px; height: 20px;
            border-bottom: 2px solid #00f3ff;
            border-right: 2px solid #00f3ff;
            opacity: 0.7;
            transition: width 0.3s, height 0.3s;
        }

        .hud-panel:hover {
            border-color: rgba(0, 243, 255, 0.6);
            box-shadow: 0 0 30px rgba(0, 243, 255, 0.2), inset 0 0 20px rgba(0, 243, 255, 0.1);
            transform: translateY(-3px);
            cursor: pointer;
        }
        .hud-panel:hover::before, .hud-panel:hover::after {
            width: 40px; height: 40px;
        }

        /* Crypto Chart Animation */
        @keyframes cryptoRise {
            0% { transform: scaleY(0); opacity: 0; }
            100% { transform: scaleY(1); opacity: 1; }
        }
        .crypto-candle {
            opacity: 0;
            transform-origin: bottom;
        }

        .text-neon {
            color: #00f3ff;
            text-shadow: 0 0 10px rgba(0,243,255,0.4);
        }

        /* Tech Tags Sector */
        .tech-tag {
            background: rgba(3, 11, 20, 0.9);
            border: 1px solid rgba(0, 243, 255, 0.3);
            color: #00f3ff;
            padding: 10px 20px;
            border-radius: 4px;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 600;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: inset 0 0 10px rgba(0, 243, 255, 0.05);
            cursor: default;
        }
        .tech-tag:hover {
            background: rgba(0, 243, 255, 0.1);
            box-shadow: 0 0 15px rgba(0, 243, 255, 0.4), inset 0 0 15px rgba(0, 243, 255, 0.2);
            transform: scale(1.05);
            border-color: #00f3ff;
            color: white;
        }

        /* Modal Transitions */
        .modal-active { display: flex !important; }

        /* Data Readout styles */
        .data-readout {
            font-family: 'Fira Code', monospace;
            font-size: 0.7rem;
            color: rgba(0, 243, 255, 0.6);
            position: absolute;
            pointer-events: none;
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #030b14; border-left: 1px solid rgba(0,243,255,0.1); }
        ::-webkit-scrollbar-thumb { background: rgba(0, 243, 255, 0.3); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0, 243, 255, 0.6); }

        /* Splash Screen */
        #splash-screen {
            background-color: #030b14;
        }

        /* Professional Staggered Entrance Animations */
        .assemble-element {
            opacity: 0;
            transform: translateY(60px) scale(0.95);
            transition: opacity 0.8s cubic-bezier(0.1, 0.9, 0.2, 1), transform 0.8s cubic-bezier(0.1, 0.9, 0.2, 1);
            will-change: opacity, transform;
        }

        .assemble-element.in-view {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
        
        /* Drop From Above Animation */
        .drop-element {
            opacity: 0;
            transform: translateY(-150px) scale(0.9);
            transition: opacity 1s cubic-bezier(0.34, 1.56, 0.64, 1), transform 1s cubic-bezier(0.34, 1.56, 0.64, 1);
            will-change: opacity, transform;
        }
        .drop-element.in-view {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        /* Heavy Drop Animation specifically for Hello Bro */
        .drop-heavy-element {
            opacity: 0;
            transform: translateY(-800px) scale(1.05);
            transition: opacity 1.2s cubic-bezier(0.18, 0.89, 0.32, 1.28), transform 1.2s cubic-bezier(0.18, 0.89, 0.32, 1.28);
            will-change: opacity, transform;
        }
        .drop-heavy-element.in-view {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        /* Continuous drag spinner class */
        .draggable-spinner {
            cursor: grab;
            transform-style: preserve-3d;
            perspective: 1200px;
            user-select: none;
            -webkit-user-select: none;
        }
        .draggable-spinner:active {
            cursor: grabbing;
        }

        /* 3D Spin Hover Effect */
        .spin-card-hover {
            transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease, border-color 0.3s ease;
            transform-style: preserve-3d;
            perspective: 1000px;
        }
        .spin-card-hover:hover {
            transform: rotateY(360deg);
            z-index: 20;
            border-color: #00f3ff;
            box-shadow: 0 0 30px rgba(0,243,255,0.2);
        }

        /* Top elements load naturally on click */
        .site-active .natural-load {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        /* HUD Circle Animations for Splash */
        .hud-circle {
            position: absolute;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
        }
        .hud-circle-1 { width: 350px; height: 350px; border: 1px solid rgba(0, 243, 255, 0.1); border-top: 3px solid #00f3ff; animation: spin 4s linear infinite; }
        .hud-circle-2 { width: 500px; height: 500px; border: 1px dashed rgba(0, 243, 255, 0.2); border-bottom: 3px solid #00f3ff; animation: spin 8s linear infinite reverse; }
        .hud-circle-3 { width: 750px; height: 750px; border: 2px dotted rgba(0, 243, 255, 0.1); border-left: 4px solid rgba(0,243,255,0.6); border-right: 4px solid rgba(0,243,255,0.6); animation: spin 12s linear infinite; }
        .hud-crosshair { width: 900px; height: 900px; background: conic-gradient(from 0deg, transparent 40%, rgba(0, 243, 255, 0.1) 45%, rgba(0, 243, 255, 0.4) 50%, rgba(0, 243, 255, 0.1) 55%, transparent 60%); animation: radarSpin 5s linear infinite; }
        
        /* Professional HUD Tech Button */
        .btn-hud {
            clip-path: polygon(20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%, 0 20px);
            background: rgba(0, 243, 255, 0.05);
            position: relative;
        }
        .btn-hud::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(45deg, transparent 20px, rgba(0,243,255,0.2) 20px, rgba(0,243,255,0.2) calc(100% - 20px), transparent calc(100% - 20px));
            z-index: -1;
            transition: all 0.3s ease;
            opacity: 0;
        }
        .btn-hud:hover::before {
            opacity: 1;
        }
        .btn-hud-border {
            position: absolute;
            inset: 0;
            border-left: 2px solid #00f3ff;
            border-right: 2px solid #00f3ff;
            pointer-events: none;
        }
        .btn-hud-border::before, .btn-hud-border::after {
            content: '';
            position: absolute;
            height: 2px;
            background: #00f3ff;
        }
        .btn-hud-border::before { top: 0; left: 20px; right: 0; }
        .btn-hud-border::after { bottom: 0; left: 0; right: 20px; }

        .hud-hex-bg {
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='104' viewBox='0 0 60 104' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 104L0 86.603V51.962l30-17.32 30 17.32v34.64L30 104zm0-2L58 85.45V53.116L30 36.942 2 53.116v32.333L30 102zM30 52l-28-16v-32L30-12l28 16v32L30 52zm0-2l26-15V4L30-10.942 4 4v31L30 50z' fill='%2300f3ff' fill-opacity='0.1' fill-rule='evenodd'/%3E%3C/svg%3E");
            opacity: 0.15;
            animation: pulse-glow 3s infinite alternate;
        }

        /* Data Rain for Splash Screen */
        .hud-data-rain {
            position: absolute;
            top: 5%;
            width: 250px;
            height: 90%;
            overflow: hidden;
            font-family: 'Fira Code', monospace;
            font-size: 0.65rem;
            color: rgba(0, 243, 255, 0.6);
            line-height: 1.4;
            mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
            -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
            opacity: 0.7;
            z-index: 2;
        }
        .rain-left { left: 2%; text-shadow: 0 0 5px #00f3ff; }
        .rain-right { right: 2%; text-align: right; text-shadow: 0 0 5px #00f3ff; }
        .rain-content {
            position: absolute;
            top: -100%;
            animation: rainDrop 10s linear infinite;
        }
        @keyframes rainDrop {
            100% { top: 100%; }
        }

        @keyframes radarSpin {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }

        @keyframes spin {
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }
        
        /* Glitch Hacker Text Class */
        .hacker-cypher {
            position: relative;
            display: inline-block;
        }
        .hacker-cypher::before {
            content: attr(data-text);
            position: absolute;
            left: -2px;
            text-shadow: 2px 0 blue;
            top: 0;
            color: white;
            background: #030b14;
            overflow: hidden;
            clip: rect(0,900px,0,0); 
            animation: noise-anim 2s infinite linear alternate-reverse;
        }
        @keyframes noise-anim {
            0% { clip: rect(3px,9999px,14px,0); }
            10% { clip: rect(25px,9999px,67px,0); }
            20% { clip: rect(84px,9999px,11px,0); }
            30% { clip: rect(4px,9999px,90px,0); }
            40% { clip: rect(35px,9999px,42px,0); }
            50% { clip: rect(65px,9999px,21px,0); }
            60% { clip: rect(10px,9999px,82px,0); }
            70% { clip: rect(55px,9999px,3px,0); }
            80% { clip: rect(89px,9999px,52px,0); }
            90% { clip: rect(15px,9999px,94px,0); }
            100% { clip: rect(73px,9999px,36px,0); }
        }
    </style>
