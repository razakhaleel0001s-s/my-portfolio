            root: null,
            rootMargin: '0px',
            threshold: 0.10 // Trigger when 10% visible
        };

        const scrollObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                // Ignore elements designated to load naturally on boot (Hero section)
                if(entry.target.classList.contains('natural-load')) return;

                if (entry.isIntersecting) {
                    // element scrolled in (up or down)
                    entry.target.classList.add('in-view');
                    if(entry.target.id === 'contact-box-panel') {
                        runContactAssembly();
                    }
                } else {
                    // element scrolled out (leave screen) -> reset state for next time
                    entry.target.classList.remove('in-view');
                }
            });
        }, observerOptions);




        // --- 3D INTERACTIVE SPINNER LOGIC (HERO TERMINAL) ---
        const helloSpinner = document.getElementById('hello-bro-hero');
        if (helloSpinner) {
            let isDragging = false;
            let startMouseX = 0;
            let currentRotationZ = 0;
            let lastMouseX = 0;
            let momentumRotation = 0;

            const onMouseDown = (e) => {
                isDragging = true;
                startMouseX = e.clientX || (e.touches && e.touches[0].clientX);
                lastMouseX = startMouseX;
                helloSpinner.style.transition = 'none'; // Instant follow on drag
            };

            const onMouseMove = (e) => {
                if (!isDragging) return;
                const clientX = e.clientX || (e.touches && e.touches[0].clientX);
                if (!clientX) return;
                
                const diffX = clientX - lastMouseX;
                
                // Drastic drag scaling to make it behave like a frictionless fidget spinner
                momentumRotation = diffX * 2.5; 
                currentRotationZ += momentumRotation;
                
                // Standard Z-axis rotate instead of 3D flip
                helloSpinner.style.transform = `rotate(${currentRotationZ}deg)`; 
                
                lastMouseX = clientX;
            };

            const onMouseUp = () => {
                if (!isDragging) return;
                isDragging = false;
                
                // Set an extreme springy, bouncy transition
                helloSpinner.style.transition = 'transform 2s cubic-bezier(0.2, 1.2, 0.3, 1.1)';
                
                // Snap EXACTLY back to 0, causing it to quickly "unwind" or "snap back" to upright position!
                currentRotationZ = 0; 
                helloSpinner.style.transform = `rotate(0deg)`;
            };

            helloSpinner.addEventListener('mousedown', onMouseDown);
            document.addEventListener('mousemove', onMouseMove);
            document.addEventListener('mouseup', onMouseUp);
            // Mobile Touch Support
            helloSpinner.addEventListener('touchstart', onMouseDown, {passive: true});
            document.addEventListener('touchmove', onMouseMove, {passive: true});
            document.addEventListener('touchend', onMouseUp);
        }

        // --- HACKER CYPHER REVEAL ANIMATION ---
        function runDecryption() {
            const hackerText = document.getElementById('hacker-name');
            const finalWord = "KHALEEL RAZA'S";
            const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()";
            let iterations = 0;
            
            const interval = setInterval(() => {
                hackerText.innerText = finalWord.split('').map((letter, index) => {
                    if (index < iterations) {
                        return finalWord[index];
                    }
                    return chars[Math.floor(Math.random() * chars.length)];
                }).join('');
                
                if (iterations >= finalWord.length) {
                    clearInterval(interval);
                }
                iterations += 1 / 4; // Tweak this for speed
            }, 30);
        }

