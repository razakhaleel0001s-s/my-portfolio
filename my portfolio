        // --- RA.ONE BLOCK ASSEMBLY ANIMATION ---
        function runRaOneAssembly() {
            const devTerminal = document.getElementById('hello-bro-hero');
            if(!devTerminal) return;
            
            // Set the devTerminal to spin into place like a fidget spinner
            // We use standard rotate() for the Z-axis (steering wheel / fidget spinner entrance)
            devTerminal.style.transform = 'rotate(-2880deg) scale(0.2)';
            
            const overlay = document.createElement('div');
            overlay.className = 'absolute inset-0 z-50 flex flex-wrap pointer-events-none rounded';
            overlay.style.perspective = '1000px'; 
            
            // Hide terminal content during construction
            const content = Array.from(devTerminal.children);
            content.forEach(el => {
                if(!el.classList.contains('absolute')) {
                    el.style.opacity = '0';
                    el.style.transition = 'opacity 0.6s ease-in';
                }
            });

            // 10x10 grid for much smaller, more precise blocks
            const gridCols = 10;
            const gridRows = 10;
            const totalBlocks = gridCols * gridRows; // 100 blocks
            
            for(let i = 0; i < totalBlocks; i++) {
                const block = document.createElement('div');
                block.className = 'bg-neon/90 border border-white/20 shadow-[0_0_15px_#00f3ff] transition-all transform';
                block.style.width = `${100/gridCols}%`;
                block.style.height = `${100/gridRows}%`;
                
                // Exploded starting positions (very scattered like digital dust)
                const tx = (Math.random() - 0.5) * 1500; 
                const ty = (Math.random() - 0.5) * 1500;
                const tz = (Math.random() - 0.5) * 1000 + 400; 
                
                block.style.transform = `translate3d(${tx}px, ${ty}px, ${tz}px) scale(${1 + Math.random()*3})`;
                block.style.opacity = '0';
                
                overlay.appendChild(block);
                
                // Animating in VERY slowly to match Ra.One build up (slow and heavy)
                setTimeout(() => {
                    block.style.transition = 'all 1.5s cubic-bezier(0.2, 0.8, 0.2, 1)';
                    block.style.transform = 'translate3d(0,0,0) scale(1)';
                    block.style.opacity = '1';
                }, 200 + (Math.random() * 1500)); // Staggered over 1.7 seconds

                // Melt away into the final UI
                setTimeout(() => {
                    block.style.transition = 'opacity 0.8s ease-out';
                    block.style.opacity = '0';
                    content.forEach(el => el.style.opacity = '1'); // Reveal real content
                }, 2800 + (Math.random() * 500));
            }
            
            devTerminal.appendChild(overlay);

            // Execute the master Fidget Spinner Entrance (Z-axis spin)
            // It spins violently while building, slowing down flawlessly into position
            setTimeout(() => {
                devTerminal.style.transition = 'transform 3.5s cubic-bezier(0.1, 0.9, 0.2, 1)'; 
                devTerminal.style.transform = 'rotate(0deg) scale(1)';
            }, 50);

            // Show real content just as the blocks finish melting
            setTimeout(() => {
                content.forEach(el => {
                    if(!el.classList.contains('absolute')) el.style.opacity = '1';
                });
            }, 2400);

            // Cleanup overlay and reset CSS for subsequent interactions
            setTimeout(() => {
                overlay.remove();
                devTerminal.style.transition = 'none'; // So the manual drag doesn't lag
                devTerminal.style.transform = 'rotateX(0deg) rotateY(0deg)'; // Clean slate for 3D drag
            }, 4000);
        }

