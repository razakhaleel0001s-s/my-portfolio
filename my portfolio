            icon: '<i class="fas fa-rocket text-neon"></i>',
            titleEN: 'Business Digitation Benefits',
            titleHI: 'Business Ko Digital Karne Ke Fayde',
            descEN: 'A customized application solution specifically architected for your operation.',
            descHI: 'Aapke business ki zaroorat ke hisaab se bani hui special app.',
            featuresEN: [
                'Complete automation of daily business routines.',
                'Beautiful UI/UX to attract modern customers.',
                'Secure payment handling and invoice generation.',
                'Customer feedback and rating systems.'
            ],
            featuresHI: [
                'Business ke daily repetetive kamo ka automation.',
                'Naye customers ko attract karne wala behtareen design.',
                'Secure online payment, aur automatic bill banana.',
                'Grahako ka feedback lene wala system.'
            ]
        };

        function openIndustryModal(industryId) {
            const data = industriesData[industryId] || genericIndustryFallback;
            const modal = document.getElementById('projectModal');
            const box = document.getElementById('modalBox');
            const content = document.getElementById('modalContent');
            
            const title = currentLang === 'en' ? data.titleEN : data.titleHI;
            const desc = currentLang === 'en' ? data.descEN : data.descHI;
            const featureListTitle = currentLang === 'en' ? '>> WHY YOU NEED THIS?' : '>> APP BANWANE KE FAYDE';
            const features = currentLang === 'en' ? data.featuresEN : data.featuresHI;
            
            // Build features list
            let lis = '';
            features.forEach(f => {
                lis += `<li class="flex items-start gap-4 mb-4 font-tech tracking-wide text-sm">
                            <i class="fas fa-check text-emerald-400 mt-1"></i>
                            <span class="text-slate-300"> ${f}</span>
                        </li>`;
            });

            // Generate Professional Crypto Candlestick Analytics Dashboard
            const chartData = data.stats || [
                { labelEN: 'Customer Reach', labelHI: 'Naye Customers', val: '+350%', color: 'text-emerald-400' },
                { labelEN: 'Work Automation', labelHI: 'Kaam Aasan Hona', val: '+80%', color: 'text-blue-400' },
                { labelEN: 'Monthly Profit', labelHI: 'Extra Kamayi', val: '+120%', color: 'text-emerald-400' },
            ];
            
            // Build Crypto Candles Animation String
            let candlesHtml = '';
            const numCandles = window.innerWidth < 768 ? 14 : 22; // Responsive number of blocks
            let prevClose = 20; 
            for(let i=0; i<numCandles; i++) {
                // Crypto trend going UP overall!
                const trend = (i / numCandles) * 40; 
                let open = prevClose;
                let close = Math.max(10, Math.min(90, open + (Math.random() * 30 - 10) + trend));
                
                // Final massive green dildos
                if(i > numCandles - 4) {
                    close = open + (Math.random() * 20 + 20);
                }
                if (close > 95) close = 95;

                const isGreen = close >= open;
                const colorClass = isGreen ? 'bg-emerald-500' : 'bg-rose-500';
                const shadowClass = isGreen ? 'shadow-[0_0_8px_#10b981]' : 'shadow-[0_0_8px_#f43f5e]';
                
                const height = Math.abs(close - open) + 2; 
                const high = Math.min(100, Math.max(open, close) + Math.random() * 10);
                const low = Math.max(0, Math.min(open, close) - Math.random() * 10);
                const bottomPos = Math.min(open, close);
                
                candlesHtml += `
                    <div class="relative flex-1 flex justify-center h-full items-end group">
                        <div class="absolute w-[1px] ${colorClass} opacity-40 crypto-candle" style="bottom: ${low}%; height: ${high - low}%; animation: cryptoRise 1s ease-out forwards; animation-delay: ${0.2 + (i * 0.05)}s;"></div>
                        <div class="absolute w-full max-w-[12px] ${colorClass} ${shadowClass} rounded-[1px] crypto-candle" 
                             style="bottom: ${bottomPos}%; height: ${height}%; animation: cryptoRise 1.5s cubic-bezier(0.1, 0.8, 0.2, 1) forwards; animation-delay: ${0.3 + (i * 0.05)}s;"></div>
                    </div>
                `;
                prevClose = close;
            }

            let statsHtml = '';
            chartData.forEach(stat => {
                const label = currentLang === 'en' ? stat.labelEN : stat.labelHI;
                statsHtml += `
                    <div class="text-center p-2 bg-slate-800/40 rounded border border-slate-700/50">
                        <div class="text-[9px] md:text-[10px] text-slate-400 font-mono uppercase tracking-wider mb-1 leading-tight line-clamp-2">${label}</div>
                        <div class="text-xs md:text-sm font-bold font-tech ${stat.color} drop-shadow-[0_0_5px_currentColor]">${stat.val}</div>
                    </div>
                `;
            });

            let chartHtml = `
            <div class="mt-8 mb-10 p-4 bg-[#0a0f18] border border-slate-800 rounded-lg shadow-xl relative overflow-hidden">
                <!-- Grid lines -->
                <div class="absolute inset-0 z-0 flex flex-col justify-between opacity-10 pointer-events-none p-4">
                    <div class="border-b border-neon w-full h-px"></div>
                    <div class="border-b border-neon w-full h-px"></div>
                    <div class="border-b border-neon w-full h-px"></div>
                    <div class="border-b border-neon w-full h-px"></div>
                </div>
                
                <!-- Title -->
                <div class="relative z-10 flex justify-between items-center mb-6">
                    <h4 class="text-[10px] md:text-xs font-tech font-bold text-slate-300 tracking-widest uppercase flex items-center">
                        <i class="fab fa-bitcoin text-yellow-500 mr-2 text-sm"></i> ${currentLang === 'en' ? 'Projected App Market Growth' : 'App Ka Market Growth Data'}
                    </h4>
                    <span class="text-emerald-500 text-[9px] font-mono bg-emerald-500/10 border border-emerald-500/30 px-2 py-0.5 rounded flex items-center gap-1">LIVE <i class="fas fa-circle animate-pulse text-[6px]"></i></span>
                </div>
                
                <!-- The Crypto Candlestick Chart Area -->
                <div class="relative z-10 h-28 md:h-36 w-full flex items-end justify-between px-1 pb-4 border-b-2 border-slate-700 space-x-[2px] md:space-x-1">
                    ${candlesHtml}
                </div>
                
                <!-- The customized Stats below the chart -->
                <div class="relative z-10 grid grid-cols-3 gap-2 mt-4 pt-2">
                   ${statsHtml}
                </div>
            </div>`;

            content.innerHTML = `
                <div class="flex items-center gap-6 mb-8 border-b border-neon/30 pb-6 pr-8">
                    <div class="w-16 h-16 md:w-20 md:h-20 shrink-0 bg-dark border border-neon rounded-sm flex items-center justify-center text-3xl shadow-[0_0_15px_rgba(0,243,255,0.2)]">
                        ${data.icon}
                    </div>
                    <div>
                        <h3 class="text-2xl md:text-3xl font-tech font-bold text-white tracking-widest uppercase text-shadow-neon shadow-neon">${title}</h3>
                        <div class="inline-flex mt-3 px-3 py-1 border border-neon text-neon text-[10px] bg-neon/10 font-mono tracking-widest uppercase">
                            RECOMMENDED SOLUTION
                        </div>
                    </div>
                </div>
                
                <p class="text-neon/80 text-sm font-mono leading-relaxed mb-8 pl-4 border-l-2 border-neon">
                    /* ${desc} */
                </p>
                
                ${chartHtml}
                
                <h4 class="text-lg font-tech font-bold text-white mb-6 tracking-widest uppercase">${featureListTitle}</h4>
                <ul class="text-left text-neon/90">
                    ${lis}
                </ul>
                
                <!-- Call to action button inside modal -->
                <div class="mt-8 pt-6 border-t border-neon/20">
                    <a href="#contact" onclick="closeModal()" class="inline-block bg-neon text-dark font-bold font-tech px-6 py-2 rounded shadow-[0_0_15px_rgba(0,243,255,0.4)] hover:bg-white transition uppercase">
                        ${currentLang === 'en' ? 'Discuss My Project' : 'Apne Kaam Ki Baat Karein'}
                    </a>
                </div>
            `;

            modal.classList.remove('hidden');
            modal.classList.add('modal-active');
            
            setTimeout(() => {
                box.classList.remove('opacity-0', 'scale-95');
                box.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function openModal(projectId) {
            const data = projectsData[projectId];
            const modal = document.getElementById('projectModal');
            const box = document.getElementById('modalBox');
            const content = document.getElementById('modalContent');
            
            const title = currentLang === 'en' ? data.titleEN : data.titleHI;
            const status = currentLang === 'en' ? data.statusEN : data.statusHI;
            const desc = currentLang === 'en' ? data.descEN : data.descHI;
            const featureListTitle = currentLang === 'en' ? '>> ARCHITECTURE_FEATURES' : '>> APP_KI_KHAABIYAAN';
            const features = currentLang === 'en' ? data.featuresEN : data.featuresHI;
            
            // Generate Features List
            let lis = '';
            features.forEach(f => {
                lis += `<li class="flex items-start gap-4 mb-4 font-tech tracking-wide text-sm">
                            <i class="fas fa-angle-right text-neon mt-1"></i>
                            <span class="text-slate-300"> ${f}</span>
                        </li>`;
            });

            // Generate Images Layout if they exist
            let imagesHtml = '';
            if (data.images && data.images.length > 0) {
                imagesHtml = `
                    <h4 class="text-lg font-tech font-bold text-white mb-2 mt-8 tracking-widest uppercase">>> VISUAL_DATA (SCREENSHOTS)</h4>
                    <div class="flex gap-4 overflow-x-auto py-4 snap-x border-y border-neon/20 mb-6 bg-dark/50 p-4">
                `;
                data.images.forEach((img, index) => {
                    // Fallback to a placeholder if the user hasn't put the image files in the right place yet
                    imagesHtml += `<img src="${img}" alt="Screenshot ${index+1}" class="h-[400px] w-auto rounded border border-neon/40 object-contain snap-center shrink-0 shadow-[0_0_15px_rgba(0,243,255,0.1)]" onerror="this.src='https://via.placeholder.com/300x500/030b14/00f3ff?text=Insert+Image+Here'">`;
                });
                imagesHtml += `
                    </div>
                `;
            }
            
            // Generate Play Store Badge
            let playStoreBtnHtml = '';
            if (status.includes('PLAY') || status.includes('LIVE') || status.includes('READY')) {
                playStoreBtnHtml = `
                    <div class="mt-10 mb-2">
                        <a href="#projects" onclick="closeModal()" class="inline-flex items-center gap-4 bg-black hover:bg-slate-900 border border-slate-700 hover:border-emerald-500 transition-all px-6 py-2 rounded-lg cursor-pointer max-w-fit shadow-[0_0_20px_rgba(0,0,0,0.8)]">
                            <i class="fab fa-google-play text-3xl text-emerald-500"></i>
                            <div class="text-left font-sans">
                                <div class="text-[9px] text-slate-300 uppercase tracking-widest font-semibold">GET IT ON</div>
                                <div class="text-xl text-white font-bold tracking-tight">Google Play</div>
                            </div>
                        </a>
                    </div>
                `;
            }

            content.innerHTML = `
                <div class="flex items-center gap-6 mb-8 border-b border-neon/30 pb-6 pr-8">
                    <div class="w-16 h-16 md:w-20 md:h-20 shrink-0 bg-dark border border-neon rounded-sm flex items-center justify-center text-3xl shadow-[0_0_15px_rgba(0,243,255,0.2)]">
                        ${data.icon}
                    </div>
                    <div>
                        <h3 class="text-2xl md:text-3xl font-tech font-bold text-white tracking-widest uppercase text-shadow-neon shadow-neon">${title}</h3>
                        <div class="inline-flex mt-3 px-3 py-1 border ${data.badgeStyle} text-[10px] font-mono tracking-widest uppercase">
                            ${status}
                        </div>
                    </div>
                </div>
                
                <p class="text-neon/80 text-sm font-mono leading-relaxed mb-10 pl-4 border-l-2 border-neon">
                    /* ${desc} */
                </p>
                
                ${imagesHtml}
                
                <h4 class="text-lg font-tech font-bold text-white mb-6 tracking-widest uppercase">${featureListTitle}</h4>
                <ul class="text-left text-neon/90">
                    ${lis}
                </ul>
                
                ${playStoreBtnHtml}
            `;

            modal.classList.remove('hidden');
            modal.classList.add('modal-active');
            
            setTimeout(() => {
                box.classList.remove('opacity-0', 'scale-95');
                box.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeModal() {
            const modal = document.getElementById('projectModal');
            const box = document.getElementById('modalBox');
            
            box.classList.remove('opacity-100', 'scale-100');
            box.classList.add('opacity-0', 'scale-95');
            
            setTimeout(() => {
                modal.classList.remove('modal-active');
                modal.classList.add('hidden');
            }, 300);
        }
    </script>
</body>
</html>
